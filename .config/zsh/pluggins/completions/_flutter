#compdef flutter

_flutter() {
  local si=$IFS
  IFS=$'\n'
  compadd -- $(COMP_CWORD=$((CURRENT-1)) \
               COMP_LINE=$BUFFER \
               COMP_POINT=$CURSOR \
               flutter completion -- "${words[@]}" \
               2>/dev/null)
  IFS=$si
}

if [ "$funcstack[1]" = "_flutter" ]; then
    _flutter "$@"
fi

#compdef flutter

_flutter() {
  local si=$IFS
  compadd -- $(COMP_CWORD=$((CURRENT-1)) \
               COMP_LINE=$BUFFER \
               COMP_POINT=0 \
               flutter completion -- "${words[@]}" \
               2>/dev/null)
  IFS=$si
}

# If the script is being executed as a completion function, call it.
if [ "$funcstack[1]" = "_flutter" ]; then
    _flutter "$@"
fi
